From 57cb1ec16d3c9819cbb9d0f0e3ad2be64f43ec89 Mon Sep 17 00:00:00 2001
From: Stelios Tsampas <loathingkernel@gmail.com>
Date: Wed, 11 Mar 2026 22:12:00 +0200
Subject: [PATCH 1/3] umu_proton: add special case `umu-host` tool to satisfy
 `UMU_NO_PROTON=1` fallback

This tool is not invokable externally, it exists to satisfy `UMU_NO_PROTON=1`
semantics when a non-runtime proton is executed. This tool just runs something on
the host, like other tools would run the same linux binary in their respective
runtime.
---
 umu/umu_proton.py | 21 ++++++++++++---------
 umu/umu_run.py    |  4 +++-
 2 files changed, 15 insertions(+), 10 deletions(-)

diff --git a/umu/umu_proton.py b/umu/umu_proton.py
index f5ef58c..abdace2 100644
--- a/umu/umu_proton.py
+++ b/umu/umu_proton.py
@@ -61,6 +61,8 @@ class ProtonVersion(Enum):
     UMUSniper_arm64 = "umu-sniper-arm64"
     UMUSteamRT4 = "umu-steamrt4"
     UMUSteamRT4_arm64 = "umu-steamrt4-arm64"
+    # Special case, non-invokable
+    UMUHost = "umu-host"
 
 
 def get_umu_proton(env: dict[str, str], session_pools: SessionPools) -> dict[str, str]:
@@ -124,6 +126,7 @@ def _get_umu_runtime_tool(env: dict[str, str], name: str) -> dict[str, str] | No
             ProtonVersion.UMUSniper_arm64.value,
             ProtonVersion.UMUSteamRT4.value,
             ProtonVersion.UMUSteamRT4_arm64.value,
+            ProtonVersion.UMUHost.value,
         }
     ):
         return None
@@ -155,16 +158,16 @@ def _get_umu_runtime_tool(env: dict[str, str], name: str) -> dict[str, str] | No
             }
         }
     }
-    toolmanifest = {
-        "manifest": {
-            "version": "2",
-            "commandline": "/entry-point",
-            "require_tool_appid": rt_appid,
-            "use_sessions": "1",
-            # special value, see CompatLayer.layer_name()
-            "compatmanager_layer_name": "umu-passthrough",
-        }
+    manifest = {
+        "version": "2",
+        "commandline": "/entry-point",
+        "use_sessions": "1",
+        # special value, see CompatLayer.layer_name()
+        "compatmanager_layer_name": "umu-passthrough",
     }
+    if rt_appid:
+        manifest["require_tool_appid"] = rt_appid
+    toolmanifest = { "manifest": manifest }
 
     if not tool_path.is_dir():
         tool_path.mkdir(parents=True, exist_ok=True)
diff --git a/umu/umu_run.py b/umu/umu_run.py
index 90ba7a4..39dba48 100755
--- a/umu/umu_run.py
+++ b/umu/umu_run.py
@@ -933,7 +933,9 @@ def umu_run(args: Namespace | tuple[str, list[str]]) -> int:
         # Setup the launcher and runtime files
         _, do_download = check_env(env)
 
-        if runtime_variant:
+        if runtime_name == "host":
+            download_proton(env, session_pools, download=do_download)
+        elif runtime_variant:
             UMU_LOCAL.joinpath(runtime_variant).mkdir(parents=True, exist_ok=True)
 
             future: Future = thread_pool.submit(
-- 
