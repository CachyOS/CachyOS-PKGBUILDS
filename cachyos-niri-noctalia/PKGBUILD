# Maintainer: Lysec <admin@lysec.dev>

pkgname=cachyos-niri-noctalia
pkgdesc='CachyOS Niri (+Noctalia) settings'
pkgver=1.1.2
pkgrel=1
arch=('any')
url="https://github.com/cachyos/$pkgname"
license=(GPL-3.0-only)
makedepends=('coreutils' 'git')
install=$pkgname.install
source=(git+$url#tag=${pkgver})
sha512sums=('208033ec3fb65ccba913fd6e7db3a07aed86d581f1343f87bffb043f7d19046f16590dbb011eb1807cfed7a31653a610981e13c0b9091f32bf60b0a31cc5b1e4')
depends=(
  adw-gtk-theme
  cachyos-alacritty-config
  capitaine-cursors
  gnome-keyring
  niri
  noctalia-shell
  noto-fonts
  noto-fonts-emoji
  wl-clipboard
  xdg-desktop-portal-gnome
  xdg-desktop-portal-gtk
  xwayland-satellite
)
provides=('cachyos-desktop-settings')
conflicts=('cachyos-desktop-settings')

package() {
  install -d "${pkgdir}/etc"
  cp -rf "${srcdir}/${pkgname}/etc" "${pkgdir}"
}
