pkgname=cachyos-snapper-support
pkgver=1.0.3
pkgrel=1
pkgdesc='CachyOS package that handles snapper configs.'
arch=(any)
url='https://github.com/CachyOS/CachyOS-PKGBUILDS/cachyos-snapper-support'
license=(GPL-3.0-or-later)
depends=(snapper snap-pac polkit)
makedepends=(git)
conflicts=(timeshift)
source=('snapper-template-root-cachyos'
        'cachyos-restore-installation'
        'cachyos-restore-installation-ui'
        'cachyos-restore-installation.desktop'
        'org.cachyos.restore-installation.policy')
sha512sums=('44b2027a7e772fbe5f499d1a387d68ec873747774b89b0dfd0967a9bb5b4991c917e2be341da123b7c40c712c15dc8e02f2172a83155ec40ed866e8ae4e0027a'
            '4276f2e05887b5f9a66d57369ef826aa87088618a51cdb4b5990ffd897f1d1fc19ed0237e9683acbfe5a4d4a50979eaef26d76c370c5ce2deec296b3f7306b0a'
            '5132c774b0203c34eca6c18aca0036646862078c1db57dd3a8eaa224f1691316a555cdac7256edd1e6aabd872ace8481215a3eb11f0b6055ea1ef57b26413ef5'
            'fdf274752da728c5217e5253dd5b065ea9fa5566c292d1b7398c4c870faac494849c7c1a56fefefce5b4b2cc1da31cb5e80a8dd0440420ba91b85b6118fb81b4'
