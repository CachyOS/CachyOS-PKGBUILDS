install="$pkgname".install

package() {
	install -Dm644 snapper-template-root-cachyos "$pkgdir/etc/snapper/config-templates/cachyos-root"
	install -Dm755 cachyos-restore-installation "$pkgdir/usr/lib/cachyos/restore-installation"
	install -Dm755 cachyos-restore-installation-ui "$pkgdir/usr/bin/cachyos-restore-installation"
	install -Dm644 cachyos-restore-installation.desktop "$pkgdir/usr/share/applications/cachyos-restore-installation.desktop"
	install -Dm644 org.cachyos.restore-installation.policy "$pkgdir/usr/share/polkit-1/actions/org.cachyos.restore-installation.policy"
}
