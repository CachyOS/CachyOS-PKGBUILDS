# Maintainer: Nekoh

pkgname=cachyos-snapper-support
pkgver=1.0.3
pkgrel=1
pkgdesc='CachyOS package that handles snapper configs.'
arch=(any)
url='https://github.com/CachyOS/CachyOS-PKGBUILDS/cachyos-snapper-support'
license=(GPL-3.0-or-later)
depends=(snapper snap-pac polkit)
optdepends=('kdialog: confirmation dialogs for the restore-installation helper on KDE'
            'zenity: confirmation dialogs for the restore-installation helper on GTK desktops')
makedepends=(git)
conflicts=(timeshift)
source=('snapper-template-root-cachyos'
        'cachyos-restore-installation'
        'cachyos-restore-installation-ui'
        'cachyos-restore-installation.desktop'
        'org.cachyos.restore-installation.policy')
sha512sums=('44b2027a7e772fbe5f499d1a387d68ec873747774b89b0dfd0967a9bb5b4991c917e2be341da123b7c40c712c15dc8e02f2172a83155ec40ed866e8ae4e0027a'
            'c7c94a3ac9642bfe3c8862e406d17e1bc468c72fb4ab696ca22ea35bc067fb79f076933b9c0d8a40c395cbbea729aa4ea07e2877bee832209a7fd96bb2932e7b'
            'd32bed81f7b079e80cc4d7c4f11e042e7dbdd629446b52fc9a1cd357d134301f5aa05220f678a1973f844d7a55cdeb884f61ec4202cf2b25ea663c0e1ad3605a'
            'fdf274752da728c5217e5253dd5b065ea9fa5566c292d1b7398c4c870faac494849c7c1a56fefefce5b4b2cc1da31cb5e80a8dd0440420ba91b85b6118fb81b4'
            '3cfa67a5490c4e115d762239681afc42e76bb2bc9f2c8de8e7936596c87f7e45b311b5477e98670b417f02f57e22b63ed7f031dd65d3f4053cedc81bed1d4942')
install="$pkgname".install

package() {
	install -Dm644 snapper-template-root-cachyos "$pkgdir/etc/snapper/config-templates/cachyos-root"
	install -Dm755 cachyos-restore-installation "$pkgdir/usr/lib/cachyos/restore-installation"
	install -Dm755 cachyos-restore-installation-ui "$pkgdir/usr/bin/cachyos-restore-installation"
	install -Dm644 cachyos-restore-installation.desktop "$pkgdir/usr/share/applications/cachyos-restore-installation.desktop"
	install -Dm644 org.cachyos.restore-installation.policy "$pkgdir/usr/share/polkit-1/actions/org.cachyos.restore-installation.policy"
}
