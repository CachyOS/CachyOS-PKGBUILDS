# Maintainer: dr460nf1r3 <dr460nf1r3 at garudalinux dot org>
# Maintainer: Antoine Viallon <antoine@lesviallon.fr>

_pkgname=ananicy-cpp
pkgname=ananicy-cpp-cpuset-git
pkgver=1.1.1.r24.g3a33f5d
pkgrel=1
pkgdesc="Ananicy Cpp is a full rewrite of Ananicy in C++, featuring lower CPU and RAM usage."
arch=(x86_64)
url="https://gitlab.com/ananicy-cpp/ananicy-cpp"
license=('GPL-3.0-or-later')
depends=(
  gcc-libs
  glibc
  libbpf
  libelf
  libfmt.so
  libspdlog.so
  systemd
  systemd-libs
  zlib
  pcre2
)
makedepends=(
  bpf
  clang
  cmake
  git
  ninja
  nlohmann-json
)
optdepends=("cachyos-ananicy-rules-git: community rules"
            "cachyos-ananicy-rules: Rules based for ananicy-cpp")
source=("${_pkgname}::git+https://gitlab.com/ananicy-cpp/ananicy-cpp.git"
        https://gitlab.com/ananicy-cpp/ananicy-cpp/-/merge_requests/39.patch)
sha512sums=('SKIP'
            'edcda9c7d3745ddc39cb2ab74ccbb13d6d9fd053f73f6ebfc6c1fb6aa096dd4e655bba63d583be9b1d3cb409085c8201040e72f5abb7bfe34b5041a018392999')
provides=('ananicy-cpp')
conflicts=('ananicy-cpp')

pkgver() {
  cd "${srcdir}/${_pkgname}"

  git describe --tags | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${srcdir}/${_pkgname}"

  # [Feature] Add cpuset CPU affinity rules and AMD X3D support
  patch -Np1 -i ../39.patch
}

build() {
  cd "${srcdir}/${_pkgname}"

  cmake -S . -Bbuild \
        -GNinja \
        -DCMAKE_BUILD_TYPE=None \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DUSE_EXTERNAL_SPDLOG=ON \
        -DUSE_EXTERNAL_JSON=ON \
        -DUSE_EXTERNAL_FMTLIB=ON \
        -DENABLE_SYSTEMD=ON \
        -DUSE_BPF_PROC_IMPL=ON \
        -DBPF_BUILD_LIBBPF=OFF \
        -DENABLE_REGEX_SUPPORT=ON

  cmake --build build --target ananicy-cpp
}

package() {
  cd "${srcdir}/${_pkgname}"
  DESTDIR="${pkgdir}" cmake --install build --component Runtime

  install -m755 -d "${pkgdir}/etc/ananicy.d"
}

# vim:set sw=2 sts=2 et:
