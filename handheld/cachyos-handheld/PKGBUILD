pkgname=cachyos-handheld
pkgver=1.3.2
pkgrel=2
arch=('any')
license=('GPL-3.0-later')
pkgdesc='CachyOS - Handheld!'
url='https://github.com/CachyOS/CachyOS-Handheld'
source=("git+$url?signed#tag=$pkgver"
        "$pkgname-bootstrap.sh"
        "$pkgname-bootstrap.service")
install="$pkgname.install"
options=(!strip !debug)
provides=('cachyos-deckify')
replaces=('cachyos-deckify')
sha256sums=('2a8b0b0c642c46bd7446749d9bf6da434695173d44da15d3c211a4a38508d5bd'
            '1f85db667440f40bbcf610b187d3af31ace38aec8300cafc6f957fe34b9926c0'
            'e22dec12f2199359e7d667a2abb74c7c264c06fc48d344d04c08f060203c64e1')
validpgpkeys=(
  E8B9AA39F054E30E8290D492C3C4820857F654FE  # Peter Jung <admin@ptr1337.dev>
  B1B70BB1CD56047DEF31DE2EB62C3D10C54D5DA9  # Vladislav Nepogodin <nepogodin.vlad@gmail.com>
  E18447AC260021D31F3FF6C4C8A2A4774B8B63C4  # Eric Naim <dnaim@cachyos.org>
)
makedepends=('git')
depends=(
  'cachyos-alacritty-config'
  'cachyos-vapor'
  'gamescope-session-cachyos'
  'jupiter-hw-support'
  'lib32-gamescope'
  'mangohud'
  'mesa-utils'
  'plasma-login-manager'
  'scx-scheds'
  'steam'
)

package() {
  install -d "$pkgdir/etc"
  cp -rf "${srcdir}/CachyOS-Handheld/etc" "$pkgdir"
  install -d "$pkgdir/usr"
  cp -rf "${srcdir}/CachyOS-Handheld/usr" "$pkgdir"

  install -d "$pkgdir/usr/lib/firmware/ath11k"
  ln -s ./QCA2066 "$pkgdir/usr/lib/firmware/ath11k/QCA206X"

  # First-boot SteamOS bootstrap (network access is not allowed from .install)
  install -Dm755 "${srcdir}/$pkgname-bootstrap.sh" \
    "$pkgdir/usr/lib/cachyos-handheld/$pkgname-bootstrap.sh"
  install -Dm644 "${srcdir}/$pkgname-bootstrap.service" \
    "$pkgdir/usr/lib/systemd/system/$pkgname-bootstrap.service"
}
