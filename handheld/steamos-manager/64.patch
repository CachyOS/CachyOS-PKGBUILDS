From 99da9ff9ed7155d4e8ba61d4fdb0cea707a54bdb Mon Sep 17 00:00:00 2001
From: Matthew Schwartz <matthew.schwartz@linux.dev>
Date: Sat, 9 May 2026 16:53:49 -0700
Subject: [PATCH 2/2] power: handle kernel 7.1 asus-wmi charge limit change

Upstream commit 186bf9031666 ("platform/x86: asus-wmi: do not enforce a
battery charge threshold") in Linux 7.1 stops auto-writing 100 to the EC
at boot and returns -ENODATA from charge_control_end_threshold reads
until userspace writes a value, since the kernel has no way to query the
current limit from the EC.

Treat -ENODATA as unknown so BatteryChargeLimit1 doesn't error out on a
fresh boot.

Link: https://lore.kernel.org/all/20260304132608.33815-1-denis.benato@linux.dev/
---
 steamos-manager/src/power.rs | 16 ++++++++++------
 1 file changed, 10 insertions(+), 6 deletions(-)

diff --git a/steamos-manager/src/power.rs b/steamos-manager/src/power.rs
index 71da1ff..f631f55 100644
--- a/steamos-manager/src/power.rs
+++ b/steamos-manager/src/power.rs
@@ -7,6 +7,7 @@
 
 use anyhow::{Result, anyhow, bail, ensure};
 use async_trait::async_trait;
+use nix::errno::Errno;
 use num_enum::TryFromPrimitive;
 use serde::Deserialize;
 use std::collections::HashMap;
@@ -708,12 +709,15 @@ async fn find_battery_charge_path() -> Result<PathBuf> {
 pub(crate) async fn get_max_charge_level() -> Result<i32> {
     let path = find_battery_charge_path().await?;
 
-    read_to_string(path)
-        .await
-        .map_err(|message| anyhow!("Error reading sysfs: {message}"))?
-        .trim()
-        .parse()
-        .map_err(|e| anyhow!("Error parsing value: {e}"))
+    match read_to_string(path).await {
+        Ok(s) => s
+            .trim()
+            .parse()
+            .map_err(|e| anyhow!("Error parsing value: {e}")),
+        // asus-wmi may return ENODATA until userspace writes a value
+        Err(e) if e.raw_os_error().map(Errno::from_raw) == Some(Errno::ENODATA) => Ok(-1),
+        Err(e) => Err(anyhow!("Error reading sysfs: {e}")),
+    }
 }
 
 pub(crate) async fn set_max_charge_level(limit: i32) -> Result<oneshot::Receiver<SysfsWritten>> {
