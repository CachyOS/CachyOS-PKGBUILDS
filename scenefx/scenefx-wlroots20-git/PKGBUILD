# Maintainer: Seafoam Labs <developers@seafoam-labs.org>
pkgname=scenefx-wlroots20-git
_pkgname=scenefx
_branch=wlroots-0.20
pkgver=0.5
pkgrel=1
pkgdesc="Drop-in replacement for wlroots' scene API adding blur, shadows and rounded corners (wlroots-0.20 branch)"
arch=('x86_64' 'aarch64')
url="https://github.com/wlrfx/scenefx"
license=('MIT')
depends=('wlroots0.20' 'pixman' 'libdrm' 'libglvnd' 'wayland' 'libxkbcommon')
makedepends=('git' 'meson>=1.3' 'ninja' 'wayland-protocols')
provides=('scenefx' 'libscenefx-0.5.so')
conflicts=('scenefx')
source=("$_pkgname::git+https://github.com/wlrfx/scenefx.git#branch=$_branch")
sha256sums=('SKIP')

pkgver() {
    cd "$_pkgname"
    # e.g. 0.5.0.r12.gabcdef0
    printf "%s" "$(git describe --long --tags 2>/dev/null \
        | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' \
        || printf "0.5.0.r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)")"
}

build() {
    arch-meson "$_pkgname" build \
        --buildtype=release \
        -Dexamples=false \
        -Dwerror=false
    meson compile -C build
}

package() {
    meson install -C build --destdir "$pkgdir"
}
