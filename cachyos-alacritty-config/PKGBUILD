pkgname=cachyos-alacritty-config
pkgdesc='CachyOS alacritty config'
pkgver=1.1
pkgrel=1
arch=('any')
url="https://github.com/cachyos/$pkgname"
license=(GPL-1.0-only)
makedepends=('coreutils')
source=("$pkgname-$pkgver.tar.gz::$url/archive/$pkgver.tar.gz")
sha512sums=('743b9d54b704307e3acf1848931ec72310263054386f4bd764b8d0c71c1a8ee03dc163a5899dd83b8a55c69dda5c7f28dee1aab2eef38d67f466632b45248034')

package() {
    install -d $pkgdir/etc
    cp -rf $srcdir/$pkgname-$pkgver/etc $pkgdir
}
