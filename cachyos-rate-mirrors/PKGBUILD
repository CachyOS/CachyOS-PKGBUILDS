pkgname=cachyos-rate-mirrors
pkgver=23
pkgrel=3
groups=(cachyos)
arch=('any')
install=$pkgname.install
pkgdesc='CachyOS - Rate mirrors service'
url='https://github.com/CachyOS'
license=('GPL-1.0-only')
depends=('rate-mirrors')
source=(
  cachyos-rate-mirrors
  cachyos-rate-mirrors.service
  cachyos-rate-mirrors.timer
  cachyos-rate-mirrors.hook
)
sha256sums=('c8eefdede7b115ee7f4a59d6f631e491a0698c3a930c2fc2d2e9e710b4feaad2'
            'a70233ee2e082e2e5a11503f048d06c80f566be4b7d664e4afee7051befc5420'
            'e9f368a137bc20c54beea4ca349400e9a5903860cb830b5658a219546e5085f0'
            '631cd984e0b77f58be2cee48748a49eab2c56d51622e397defbf464574aec0f4')

package() {
  install -dm 0755 "$pkgdir"/usr/{bin,lib/systemd/{system,system-sleep}}
  install -dm 0755 "$pkgdir"/usr/lib/pacman/hooks
  install -dm 0755 "$pkgdir"/etc/rate-mirrors.d/
  install -Dm 0755 cachyos-rate-mirrors "$pkgdir"/usr/bin/cachyos-rate-mirrors
  install -Dm 0644 cachyos-rate-mirrors.service "$pkgdir"/usr/lib/systemd/system/cachyos-rate-mirrors.service
  install -Dm 0644 cachyos-rate-mirrors.timer "$pkgdir"/usr/lib/systemd/system/cachyos-rate-mirrors.timer
  install -Dm 0644 cachyos-rate-mirrors.hook "$pkgdir"/usr/lib/pacman/hooks/cachyos-rate-mirrors.hook
}
