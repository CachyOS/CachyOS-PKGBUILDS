post_install() {
    systemctl daemon-reload
    systemctl enable --now cachyos-rate-mirrors.timer
}

post_upgrade() {
    systemctl daemon-reload
    systemctl enable --now cachyos-rate-mirrors.timer
}

pre_remove() {
    systemctl disable --now cachyos-rate-mirrors.timer
}

post_remove() {
    systemctl daemon-reload
}
