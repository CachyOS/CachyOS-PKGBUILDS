+#ifndef PLASMALOGIN_CONFIGURATION_H
+#define PLASMALOGIN_CONFIGURATION_H
+
+#include <QtCore/QDir>
+#include <QtCore/QString>
+#include <QtCore/QStringList>
+#include <QtCore/QTextStream>
+#include <pwd.h>
+
+#include "Constants.h"
+
