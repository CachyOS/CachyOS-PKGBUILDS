pkgname='cachyos-benchmarker'
pkgver=0.8.0
pkgrel=2
pkgdesc='A simple benchmarking script using stress-ng, perf, blender etc. (CachyOS Version)'
url="https://github.com/cachyos/cachyos-benchmarker"
arch=('x86_64')
license=('GPL-3.0-or-later')
depends=(
  argon2
  bc
  blender
  cmake
  curl
  gcc
  geekbench
  git
  inxi
  libdrm
  make
  nasm
  p7zip
  perf
  primesieve
  python
  python-matplotlib
  python-numpy
  rt-tests
  schbench-git
  stress-ng
  time
  unzip
  wget
  x265
  xz
  zlib
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/cachyos/cachyos-benchmarker/archive/refs/tags/$pkgver.tar.gz")
sha512sums=('2381f22e1820df31844bf34619d003b41652e426462e9ca40701cf81dc01908137f8fa301f3b9efc8f67794860237940ad321ef52b882e65f5c88be8057b5e97')

package() {
    cd "$srcdir/$pkgname-$pkgver"
    install -Dm755 $pkgname "$pkgdir/usr/bin/$pkgname"
    install -Dm755 benchmark_scraper.py "$pkgdir/usr/bin/benchmark_scraper.py"
}
