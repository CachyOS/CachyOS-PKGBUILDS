# Maintainer: Norbert Preining <norbert@preining.info>
pkgname=intel-lpmd
pkgver=0.1.0
pkgrel=7
pkgdesc="Intel Low Power Mode Daemon"
arch=('x86_64')
url="https://github.com/cachyos/$pkgname"
license=('GPL-2.0-or-later')
makedepends=(
  git
  automake
  autoconf-archive
  gtk-doc
  glib2-devel
  systemd
)
depends=(
  glib2
  glibc
  libnl
  libxml2
  polkit
  systemd-libs
  upower
)
source=(git+${url}.git#commit=7fbe6dfac9d9148cd0fbeb9fb29f5c686ae9c226)
sha256sums=('fc9162d51972fc1913f4722f11af3ec9067311126c7de4d4c7c59645dac386c0')

prepare() {
	cd "$pkgname"
	./autogen.sh prefix=/usr sysconfdir=/etc sbindir=/usr/bin
}

build() {
	cd "$pkgname"
	make
}

package() {
	cd "$pkgname"
	DESTDIR="$pkgdir" make install
	install -Dm 644 -t "${pkgdir}/usr/share/doc/${pkgname}" "$srcdir/${pkgname}"/README.md
	install -Dm 644 -t "${pkgdir}/usr/share/doc/${pkgname}" "$srcdir/${pkgname}"/doc/WLT_proxy.md
}
